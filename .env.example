# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Cloudinary — free account at cloudinary.com, create an "unsigned" upload preset
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=tastebueno_uploads

# Netlify sets this automatically in production
URL=https://tastebueno.com
